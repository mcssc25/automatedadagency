PORT=3000
PUBLIC_APP_URL=https://agents.realestatecrmpro.com
ADMIN_AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password_before_production
GEMINI_API_KEY=your_gemini_api_key
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_RESEARCH_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
GEMINI_VIDEO_MODEL=gemini-omni-flash-preview

# Optional low-cost LLM provider for hidden lead-intelligence research.
# Keep the real key in .env only; never commit it.
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_DEFAULT_MODEL=openrouter/free
OPENROUTER_RESEARCH_MODEL=openai/gpt-oss-120b:free
OPENROUTER_WEB_SEARCH_ENABLED=false
OPENROUTER_WEB_SEARCH_MAX_RESULTS=5
OPENROUTER_DAILY_REQUEST_LIMIT=200
OPENROUTER_APP_NAME=Real Estate CRM Pro Lead Intelligence
LEAD_INTELLIGENCE_RESEARCH_PROVIDER=openrouter

MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=outreach.realestatecrmpro.com
MAILGUN_FROM_EMAIL=Sales at Real Estate CRM Pro <sales@outreach.realestatecrmpro.com>
MAILGUN_WEBHOOK_SIGNING_KEY=your_mailgun_webhook_signing_key
REQUIRE_MAILGUN_WEBHOOK_SIGNATURE=true
OUTBOUND_POSTAL_ADDRESS=Your business mailing address
EMAIL_COMPLIANCE_REQUIRED=true
CORS_ALLOWED_ORIGINS=https://agents.realestatecrmpro.com

# DNC removal is disabled by default. Set only for deliberate admin recovery.
ALLOW_DNC_REMOVAL=false
